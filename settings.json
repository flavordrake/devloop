{
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "WebSearch",
      "WebFetch",
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(ls *)",
      "Bash(tree *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(diff *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(date *)",
      "Bash(test *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rm *)",
      "Bash(chmod *)",
      "Bash(echo *)",
      "Bash(env *)",
      "Bash(export *)",
      "Bash(ps *)",
      "Bash(sort *)",
      "Bash(sleep *)",
      "Bash(python3 *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/dev/workspace/.claude/hooks/enforce-hygiene.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "/home/dev/workspace/.claude/hooks/trace-signal.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/dev/workspace/.claude/hooks/trace-signal.sh"
          }
        ]
      }
    ]
  }
}
